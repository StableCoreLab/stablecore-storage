root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,c,cc,cxx,inl,ixx,cppm}]
indent_style = space
indent_size = 4

[*.{cmake,txt,md,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.vcxproj]
indent_style = space
indent_size = 2